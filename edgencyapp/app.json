{
  "expo": {
    "name": "edgencyapp",
    "slug": "edgencyapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "edgencyapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "assetBundlePatterns": [
      "assets/images/*",
      "assets/rag/*",
      "assets/fonts/*"
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Edgency uses your camera to capture and share your situation with emergency services.",
        "NSMicrophoneUsageDescription": "Edgency uses your microphone so you can send voice messages when it's not safe to type.",
        "NSPhotoLibraryUsageDescription": "Edgency accesses your photos so you can share your location visually.",
        "NSLocationWhenInUseUsageDescription": "Edgency shares your location with the AI to provide accurate emergency guidance and evacuation routes."
      }
    },
    "android": {
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.VIBRATE",
        "android.permission.SEND_SMS"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/edgency-adaptive-icon-foreground.png",
        "backgroundImage": "./assets/images/edgency-adaptive-icon-background.png",
        "monochromeImage": "./assets/images/edgency-adaptive-icon-background.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.natx.edgencyapp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/edgency-splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-build-properties",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 29
          }
        }
      ],
      "@qvac/sdk/expo-plugin",
      "expo-sqlite",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/edgency-logo.png",
          "color": "#E6F4FE",
          "defaultChannel": "edgency-checkins"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "79b54cb0-1434-4ba0-ab58-8419fee6d153"
      }
    }
  }
}
